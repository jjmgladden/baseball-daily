# Baseball Daily Intelligence — Environment Template
# Copy this file to .env (which is gitignored) and fill in real values.
# NEVER commit the populated .env file.

# YouTube Data API v3 — required for highlight ingestion (Phase 3 feature).
# Acquisition deferred until ingestion blocks on it.
# Get at: https://console.cloud.google.com → APIs & Services → Credentials
# Restrict the key to YouTube Data API v3, and optionally to your home IP.
YOUTUBE_API_KEY=

# Optional: override default team IDs. Defaults match MLB Stats API.
# PRIMARY_TEAM_ID=138
# SECONDARY_TEAM_ID=120
